# Postgres connection string for the plugin's backend.
#
# The plugin owns an `inventory` SCHEMA (not its own database) and
# schema-qualifies every query, so this is normally just a copy of the panel's
# own connection string. Copy it out of the cluster:
#
#   kubectl -n 5stack get secret -o name | grep timescaledb-secrets
#   kubectl -n 5stack get secret <that-name> \
#     -o jsonpath='{.data.POSTGRES_CONNECTION_STRING}' | base64 -d
#
# Copy this file to inventory-secrets.env (gitignored) and fill it in.
DATABASE_URL=postgres://hasura:CHANGEME@timescaledb:5432/hasura
