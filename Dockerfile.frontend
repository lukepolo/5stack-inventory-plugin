# Builds the Module Federation remote (remoteEntry.js + assets) and serves it as
# static files. @5stack/ui must be resolvable at install time (published to your
# registry, or vendored / yarn-linked for local builds).
FROM node:22-alpine AS build
WORKDIR /app
COPY package.json ./
RUN npm install
COPY . .
RUN npm run build

FROM nginx:alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
